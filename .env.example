# AI 代理服务器配置
# 复制此文件为 .env 并填入你的 API Key
#
# 支持的大模型平台（任选一个）：
#   智谱GLM:  https://open.bigmodel.cn/api/paas/v4  模型: glm-4-flash (免费)
#   DeepSeek: https://api.deepseek.com               模型: deepseek-chat
#   通义千问:  https://dashscope.aliyuncs.com/compatible-mode/v1  模型: qwen-turbo

AI_API_KEY=你的API密钥
AI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
AI_MODEL=glm-4-flash
